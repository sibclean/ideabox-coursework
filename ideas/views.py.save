def send_html_notification(subject, to_email, title, message, action_url=None, action_text="Перейти"):
    context = {'title': title, 'message': message, 'action_url': action_url, 'action_text': action_text}
    html_body = render_to_string('emails/notification.html', context)
    email = EmailMultiAlternatives(subject, strip_tags(html_body), settings.EMAIL_HOST_USER, [to_email])
    email.attach_alternative(html_body, "text/html")
    email.send(fail_silently=True)

def idea_list(request):
    ideas_queryset = Idea.objects.filter(status='APP').select_related(
        'author', 'author__profile'
    ).prefetch_related('categories').order_by('-created_at')
    
    search_query = request.GET.get('q', '').strip()
    current_tags = request.GET.get('role', request.GET.get('tags', '')).strip() 
    current_category = request.GET.get('category', '').strip()
    if current_category:
        if current_category.isdigit():
            ideas_queryset = ideas_queryset.filter(categories__id=int(current_category))
        else:
            ideas_queryset = ideas_queryset.filter(categories__name__icontains=current_category)
    if current_tags:
        ideas_queryset = ideas_queryset.filter(required_people_tags__icontains=current_tags)  
    if search_query:
        ideas_queryset = ideas_queryset.filter(
            Q(title__icontains=search_query) | Q(description__icontains=search_query)
        )
    ideas_queryset = ideas_queryset.distinct()
    return render(request, 'ideas/idea_list.html', {
        'ideas': ideas_queryset,
        'categories': Category.objects.all(),
        'current_category': current_category,
        'current_tags': current_tags,
        'search_query': search_query,
    })

def register(request):
    if request.method == 'POST':
        form = UserRegistrationForm(request.POST) 
        if form.is_valid():
            user = form.save(commit=False); user.is_active = False; user.save()
            current_site = get_current_site(request)
            uid = urlsafe_base64_encode(force_bytes(user.pk))
            token = default_token_generator.make_token(user)
            activate_url = f"https://{current_site.domain}/activate/{uid}/{token}/"
            send_html_notification('Активация IdeaBox', user.email, 'Добро пожаловать!', 'Подтвердите почту.', activate_url, 'Подтвердить')
            return render(request, 'registration/email_confirmation_sent.html', {'email': user.email})
    else: form = UserRegistrationForm()
    return render(request, 'registration/register.html', {'form': form})

def activate(request, uidb64, token):
    try:
        uid = force_str(urlsafe_base64_decode(uidb64))
        user = User.objects.get(pk=uid)
    except: user = None
    if user is not None and default_token_generator.check_token(user, token):
        user.is_active = True; user.save()
        login(request, user, backend='django.contrib.auth.backends.ModelBackend')
        return redirect('idea_list')
    return HttpResponse('Ошибка активации')

def idea_detail(request, pk):
    idea = get_object_or_404(Idea, pk=pk)
    return render(request, 'ideas/idea_detail.html', {'idea': idea})

@login_required
def idea_create(request):
    if request.method == 'POST':
        form = IdeaForm(request.POST, request.FILES)
        if form.is_valid():
            new_idea = form.save(commit=False)
            new_idea.author = request.user
            new_idea.status = 'MOD'
            new_idea.save()
            form.save_m2m() 
            
            messages.success(request, 'Идея успешно создана и отправлена на проверку!')
            return redirect('idea_list') 
    else: 
        form = IdeaForm()
        
    return render(request, 'ideas/idea_form.html', {'form': form, 'is_new': True})
@login_required
def idea_edit(request, pk):
    idea = get_object_or_404(Idea, pk=pk)
    
    # Защита: редактировать может только автор
    if idea.author != request.user: 
	        raise Http404("У вас нет прав для редактирования этого проекта.")
        
    if request.method == 'POST':
        # ВАЖНО: передаем request.FILES и instance
        form = IdeaForm(request.POST, request.FILES, instance=idea)
        if form.is_valid(): 
            form.save()
            messages.success(request, 'Профиль проекта успешно обновлен!')
            return redirect('idea_detail', pk=idea.pk)
    else: 
        form = IdeaForm(instance=idea)
        
    return render(request, 'ideas/idea_form.html', {'form': form, 'idea': idea, 'is_new': False})
@login_required
def idea_delete(request, pk):
    idea = get_object_or_404(Idea, pk=pk)
    if idea.author == request.user: idea.delete()
    return redirect('idea_list')

@login_required
def join_team(request, pk):
    idea = get_object_or_404(Idea, pk=pk)
    if TeamRequest.objects.filter(idea=idea, user=request.user).exists():
        messages.warning(request, "Вы уже отправляли заявку в эту команду!")
        return redirect('idea_detail', pk=pk) # Или куда у тебя идет редирект
    if request.method == 'POST':
        role = request.POST.get('wanted_role')
        contact = request.POST.get('contact_info')
        message = request.POST.get('about_me')
        
        TeamRequest.objects.create(
            idea=idea, user=request.user, 
            role=role, contact_info=contact, message=message
        )

        send_html_notification(
            f'🔥 Новая заявка в проект: {idea.title}',
            idea.author.email,
            'У вас новый кандидат!',
            f'Пользователь {request.user.username} хочет в команду на роль "{role}".\n'
            f'Контакты: {contact}\nСообщение: {message}',
            f"https://{get_current_site(request).domain}/my-ideas/requests/",
            "Управлять заявками"
        )
        messages.success(request, 'Ваша заявка сохранена и отправлена автору!')
    return redirect('idea_detail', pk=pk)

@login_required
def manage_requests(request):
    my_requests = TeamRequest.objects.filter(idea__author=request.user).order_by('-created_at')
    return render(request, 'ideas/manage_requests.html', {'requests': my_requests})

@login_required
def respond_to_request(request, req_id, action):
    team_req = get_object_or_404(TeamRequest, id=req_id, idea__author=request.user)
    if action == 'accept':
        team_req.status = 'accepted'
        subject = "Вас приняли в команду!"
        msg_text = f"Поздравляем! Автор идеи '{team_req.idea.title}' одобрил вашу заявку."
    else:
        team_req.status = 'rejected'
        subject = "Ответ по вашей заявке"
        msg_text = f"К сожалению, автор идеи '{team_req.idea.title}' отклонил вашу заявку."
    team_req.save()

    send_html_notification(
        subject, team_req.user.email, subject, msg_text,
        f"https://{get_current_site(request).domain}/idea/{team_req.idea.pk}/",
        "Посмотреть идею"
    )

    messages.success(request, f"Статус заявки изменен.")
    return redirect('manage_requests')

@login_required
def profile_edit(request):
    profile = request.user.profile 
    
    if request.method == 'POST':
        # ВАЖНО: добавлено request.FILES для обработки картинок (аватарок)
        form = UserProfileForm(request.POST, request.FILES, instance=profile)
        if form.is_valid():
            form.save()
            messages.success(request, 'Профиль успешно обновлен!')
            return redirect('profile_edit')
    else:
        form = UserProfileForm(instance=profile)
        
    return render(request, 'ideas/profile_form.html', {'form': form})
